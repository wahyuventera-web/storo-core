# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Site URL (used for sitemap & OG tags)
NEXT_PUBLIC_SITE_URL=https://storo.id

# SMTP (Hostinger) — notifikasi email shipping
# Event yang dikirim dari webhook Biteship: shipped (resi muncul), delivered
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=support@storo.id
SMTP_PASSWORD=
SMTP_FROM=support@storo.id
SMTP_FROM_NAME=STORO.ID

# Template Live Preview Deployment (superadmin only)
# Vercel API — generate token di vercel.com/account/tokens
VERCEL_API_TOKEN=
VERCEL_TEAM_ID=
# Cloudflare API — token scope Zone.DNS:Edit untuk zone storo.id
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
# Subdomain suffix untuk preview, hasil URL: {slug}.preview.storo.id
PREVIEW_DOMAIN_SUFFIX=preview.storo.id
PREVIEW_STORE_ID_PREFIX=preview-
# Source repo untuk template (default storoengine private repo)
STOROENGINE_REPO=PTVENTERA-AI/storoengine

# Sharelink.id referral integration
# Storo TIDAK punya tenant Sharelink sendiri. Storo + Salesmetrix share satu
# tenant "Ventera AI" (slug: rafli-t1tan) di Sharelink. Setiap merchant Storo
# = referrer di tenant itu, dengan metadata.referrer_source = "storo_merchant"
# yang me-route ke reward_profile "storo_merchant_credit" (lihat
# sharelink.id/scripts/setup-ventera-storo-profile.mjs).
#
# Cara dapat kredensial:
#   1. Login ke sharelink.id sebagai owner Ventera tenant (rafli.ventera@gmail.com)
#   2. /tenant/settings → Generate API key (atau pakai mrs_sk_/mrs_pk_ yang sudah ada)
#   3. Tenant ID lihat di /tenant/settings (atau query DB: slug=rafli-t1tan)
#
# Fields:
# - BASE_URL: root URL without /api/v1 suffix (default prod: https://sharelink.id)
# - SECRET_KEY: server-only Bearer token (mrs_sk_...) milik Ventera tenant
# - PUBLISHABLE_KEY: optional client-safe key untuk widget masa depan (mrs_pk_...)
# - TENANT_ID: UUID tenant Ventera AI di Sharelink (UUID milik slug rafli-t1tan)
# - INBOUND_HMAC_SECRET: shared secret untuk verify reward-distribute callbacks
#   dari Sharelink (POST /api/internal/referral/credit-applied) — set sama di
#   sharelink connector (kalau dipakai); MVP saat ini pakai PULL via listRewards
#   jadi field ini cuma kepakai kalau push webhook diaktifkan.
SHARELINK_BASE_URL=https://sharelink.id
SHARELINK_SECRET_KEY=mrs_sk_xxx
NEXT_PUBLIC_SHARELINK_PUBLISHABLE_KEY=mrs_pk_xxx
SHARELINK_TENANT_ID=
SHARELINK_INBOUND_HMAC_SECRET=

# Default reward amount (Rp) when admin creates a new referrer code.
# Overridable per-code via /superadmin/referrals. Filosofi: angka kecil
# karena reward dibayar dari subscription fee referrer (cap = monthly fee).
SHARELINK_DEFAULT_REWARD_IDR=100000
